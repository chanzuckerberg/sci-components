{
  "projectId": "a06a1e00-e6a8-49e8-af4a-2ec928d4e304",
  "shape": "storybook",
  "storybookConfigDir": ".storybook",
  "pkg": "@czi-sds/components",
  "globalName": "SDS",
  "storybookStatic": ".design-sync/sb-reference",
  "buildCmd": "node .yarn/releases/yarn-4.1.0.cjs build",
  "extraEntries": ["../../.design-sync/preview-provider.jsx", "../data-viz/dist/index.esm.js"],
  "provider": { "component": "SDSPreviewProvider" },
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "Button": { "cardMode": "column" },
    "ButtonDropdown": { "cardMode": "column" },
    "ButtonGroup": { "cardMode": "column" },
    "ButtonToggle": { "cardMode": "column" },
    "ContentCard": { "cardMode": "column" },
    "Hero": { "cardMode": "column" },
    "IntentMessage": { "cardMode": "column" },
    "Legend": { "cardMode": "column" },
    "Notification": { "cardMode": "column" },
    "Tabs": { "cardMode": "column" },
    "Tag": { "cardMode": "column" },
    "Autocomplete": { "cardMode": "column" },
    "MenuItem": { "cardMode": "column" },
    "CellBasic": { "cardMode": "column" },
    "CellComponent": { "cardMode": "column" },
    "PreComposedTable": { "cardMode": "column" },
    "Table": { "cardMode": "column" },
    "Dialog": { "cardMode": "single", "primaryStory": "Default" },
    "Panel": { "cardMode": "single", "primaryStory": "ScrollBehavior", "skip": ["components-panel--default", "components-panel--test"] },
    "Tooltip": { "cardMode": "single", "primaryStory": "Default" },
    "Dropdown": { "cardMode": "single", "primaryStory": "Default", "skip": ["components-dropdowns-dropdown--inside-modal"] },
    "DropdownMenu": { "cardMode": "single", "primaryStory": "ScreenshotTest", "skip": ["components-dropdowns-dropdownmenu--default", "components-dropdowns-dropdownmenu--multi-column", "components-dropdowns-dropdownmenu--test", "components-dropdowns-dropdownmenu--with-header-component"] }
  }
}
