{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/common/**/*",
    "src/core/**/*"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2019",
    "lib": ["es2019", "dom"],
    "paths": {
      "@data-viz/src/*": ["src/*"],
      "@components/src/*": ["../components/src/*"]
    },
    "types": ["vitest/globals", "node"]
  }
}
